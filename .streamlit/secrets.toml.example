# 複製為 .streamlit/secrets.toml（本機用；已被 .gitignore 排除，勿 commit）
# Streamlit Cloud 部署則貼到：App → Settings → Secrets
#
# Token 建立方式（Fine-grained PAT）：
#   GitHub → Settings → Developer settings → Fine-grained tokens → Generate new token
#   Repository access: Only select repositories → audachang/taipei-rental-survey
#   Permissions → Repository permissions → Contents: Read and write
GITHUB_TOKEN = "github_pat_xxxxxxxxxxxxxxxxxxxx"

# 以下皆可省略（括號內為預設值）
# GITHUB_REPO   = "audachang/taipei-rental-survey"
# GITHUB_BRANCH = "main"
# GITHUB_PATH   = "listings.json"

# Google Maps JavaScript API 金鑰（選用；設定後地圖改用 Google 底圖）
# 建議在 Google Cloud Console 對此 key 設「HTTP referrer」限制為你的 *.streamlit.app 網域
GOOGLE_MAPS_KEY = "AIzaXXXXXXXXXXXXXXXXXXXX"
